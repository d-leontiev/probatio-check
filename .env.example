# Probatio check mode runs FULLY LOCAL out-of-the-box (fail-closed — nothing leaves the machine).
# The values below are already the defaults in code; you only need a .env to OVERRIDE them.
# Prereq for the defaults: a local ollama with `ollama pull gemma4:31b` and `ollama pull embeddinggemma`.

# --- defaults (shown for reference; uncomment to change) ---
# PROBATIO_LLM_PROVIDER=litellm
# PROBATIO_VERIFY_MODEL=ollama/gemma4:31b
# PROBATIO_EMBEDDING_MODEL=ollama/embeddinggemma
# PROBATIO_OLLAMA_API_BASE=http://localhost:11434
# PROBATIO_CHECK_PASSAGES=10          # top passages the judge sees per claim (higher = fewer false "unsupported")

# --- point at a remote / Tailscale ollama instead (routes BOTH judge and embeddings there) ---
# PROBATIO_OLLAMA_API_BASE=http://your-ollama-host:11434
